---
import "@fontsource/prata/400.css";
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/600.css";
import "../styles/global.css";

const base = import.meta.env.BASE_URL;

const pillars = [
  {
    title: "Стратегия",
    text: "Выстраиваю позиционирование, контентные рубрики и сценарии под задачи проекта и аудитории.",
  },
  {
    title: "Контент",
    text: "Соединяю тексты, дизайн, фото, видео и оперативную работу на площадке в единую систему.",
  },
  {
    title: "Результат",
    text: "Работаю с цифрами, обратной связью и аналитикой, чтобы контент приносил измеримую пользу.",
  },
];

const metrics = [
  { value: "10 237", label: "участников «Студфеста — 2026»" },
  { value: "118", label: "публикаций за II квартал" },
  { value: "2 000", label: "подписчиков Telegram с нуля" },
  { value: "42", label: "поста в Telegram и VK за два месяца" },
];

const projects = [
  {
    name: "NEVEREND",
    field: "Премиальный travel",
    text: "Ежедневное сопровождение международных экспедиций — от Антарктиды до Японии. Отдельные сценарии для Telegram, Instagram и VK, репортажи, интервью и behind-the-scenes.",
    result: "+3 000 подписчиков во время экспедиции в Антарктиду",
  },
  {
    name: "VAMS smart realty",
    field: "Недвижимость",
    text: "Запуск Instagram и Telegram с нуля: позиционирование, визуальная концепция, контент-стратегия, экспертные материалы и чек-листы по районам Москвы.",
    result: "Полный цикл запуска digital-присутствия бренда",
  },
  {
    name: "Barvikha Lounge Moscow",
    field: "HoReCa",
    text: "Социальные сети трёх ресторанных проектов, организация съёмок, Reels, афиши, интеграции с блогерами, публикация и community management.",
    result: "Три бренда в едином регулярном контент-процессе",
  },
];

const skills = [
  "Контент-стратегия",
  "Digital-коммуникации",
  "Telegram-маркетинг",
  "Редактура и копирайтинг",
  "Сторителлинг",
  "Фото- и видеосъёмка",
  "Видеомонтаж",
  "Визуальные концепции",
  "Event-маркетинг",
  "Координация подрядчиков",
  "AI Content Creation",
  "Prompt Engineering",
];

const experience = [
  ["2025—2026", "Правительство Москвы", "Главный специалист отдела маркетинга и рекламы"],
  ["2025", "VAMS smart realty", "SMM-менеджер"],
  ["2024—2025", "NEVEREND", "SMM-менеджер"],
  ["2024", "Barvikha Lounge Moscow", "SMM-менеджер"],
  ["2023—2024", "Частные проекты", "Контент-маркетолог"],
  ["2021—2022", "Слетать.ру", "Руководитель отдела контента"],
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta
      name="description"
      content="Портфолио Татьяны Красавцевой — Content Manager и специалиста по digital-коммуникациям."
    />
    <meta name="theme-color" content="#57091d" />
    <meta property="og:title" content="Татьяна Красавцева — Content Manager" />
    <meta
      property="og:description"
      content="Стратегия, эстетика и измеримый результат в digital-коммуникациях."
    />
    <meta property="og:type" content="website" />
    <title>Татьяна Красавцева — Content Manager</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Перейти к содержанию</a>

    <header class="site-header" aria-label="Основная навигация">
      <a class="monogram" href="#top" aria-label="Наверх">ТК</a>
      <nav class="desktop-nav" aria-label="Разделы сайта">
        <a href="#about">Обо мне</a>
        <a href="#case">Кейс</a>
        <a href="#projects">Портфолио</a>
        <a href="#experience">Опыт</a>
      </nav>
      <a class="header-contact" href="https://t.me/tanyakrasavtseva" target="_blank" rel="noreferrer">
        Telegram
        <span aria-hidden="true">↗</span>
      </a>
    </header>

    <main id="content">
      <section class="hero" id="top" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="hero-kicker">Стратегия <i></i> Эстетика <i></i> Результат</p>
          <h1 id="hero-title">
            <span>Татьяна</span>
            <span>Красавцева</span>
          </h1>
          <p class="hero-role">Content Manager &amp;<br />специалист по digital-коммуникациям</p>
          <p class="hero-statement">
            Создаю контент, который объединяет стратегию, эстетику и измеримый результат.
          </p>
          <a class="button button-light" href="https://t.me/tanyakrasavtseva" target="_blank" rel="noreferrer">
            <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20">
              <path d="M21.6 2.7 2.8 10c-1.3.5-1.3 1.2-.2 1.5l4.8 1.5 1.9 5.8c.2.6.1.8.7.8.5 0 .7-.2 1-.5l2.3-2.2 4.8 3.6c.9.5 1.5.2 1.7-.8L23 4.3c.3-1.2-.5-1.9-1.4-1.6ZM9.2 12.6l9.4-5.9c.5-.3.9-.1.6.2l-7.8 7-.3 3.4-1.9-4.7Z" fill="currentColor" />
            </svg>
            Связаться в Telegram
          </a>
        </div>

        <div class="hero-portrait" aria-label="Портрет Татьяны Красавцевой">
          <picture>
            <source media="(max-width: 720px)" srcset={`${base}/images/tatyana-portrait-720.jpg`} />
            <img
              src={`${base}/images/tatyana-portrait-1254.jpg`}
              alt="Татьяна Красавцева в чёрном жакете"
              width="1254"
              height="1254"
              fetchpriority="high"
            />
          </picture>
          <span class="corner corner-one" aria-hidden="true"></span>
          <span class="corner corner-two" aria-hidden="true"></span>
          <span class="gold-arc" aria-hidden="true"></span>
        </div>
      </section>

      <div class="ticker" aria-hidden="true">
        <div class="ticker-track">
          <span>Контент-стратегия</span><b>✦</b>
          <span>SMM полного цикла</span><b>✦</b>
          <span>Telegram-маркетинг</span><b>✦</b>
          <span>Контент-план и рубрикатор</span><b>✦</b>
          <span>Копирайтинг и редактура</span><b>✦</b>
          <span>Reels и Shorts</span><b>✦</b>
          <span>Визуальная концепция</span><b>✦</b>
          <span>Аналитика и отчётность</span><b>✦</b>
          <span>Работа с блогерами</span><b>✦</b>
          <span>AI-инструменты в контенте</span><b>✦</b>
          <span>Event-съёмка и репортаж</span><b>✦</b>
          <span>Community management</span><b>✦</b>
          <span>Контент-стратегия</span><b>✦</b>
          <span>SMM полного цикла</span><b>✦</b>
          <span>Telegram-маркетинг</span><b>✦</b>
          <span>Контент-план и рубрикатор</span><b>✦</b>
          <span>Копирайтинг и редактура</span><b>✦</b>
          <span>Reels и Shorts</span><b>✦</b>
          <span>Визуальная концепция</span><b>✦</b>
          <span>Аналитика и отчётность</span><b>✦</b>
          <span>Работа с блогерами</span><b>✦</b>
          <span>AI-инструменты в контенте</span><b>✦</b>
          <span>Event-съёмка и репортаж</span><b>✦</b>
          <span>Community management</span><b>✦</b>
        </div>
      </div>

      <section class="about section-shell" id="about" aria-labelledby="about-title">
        <div class="about-intro">
          <h2 id="about-title">Обо мне</h2>
          <p class="about-lead">
            Content Manager с опытом полного цикла производства контента для государственных,
            коммерческих и премиальных проектов.
          </p>
          <p>
            Разрабатываю стратегии, пишу и редактирую тексты, создаю визуальные материалы,
            организую съёмки, монтирую видео и сопровождаю проекты в моменте. Умею держать
            цельную коммуникацию даже там, где много участников, площадок и этапов согласования.
          </p>
        </div>

        <ol class="pillars">
          {pillars.map((pillar) => (
            <li>
              <div>
                <h3>{pillar.title}</h3>
                <p>{pillar.text}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <section class="case-section" id="case" aria-labelledby="case-title">
        <div class="case-heading section-shell">
          <div>
            <p class="section-note">Главный кейс</p>
            <h2 id="case-title">Правительство<br />Москвы</h2>
          </div>
          <p>
            Полный цикл контент-производства и информационного сопровождения городских проектов:
            от контент-идеи и визуала до публикации, репортажа и координации подрядчиков.
          </p>
        </div>

        <div class="case-story section-shell">
          <div class="metric-column" aria-label="Результаты проекта">
            {metrics.map((metric) => (
              <div class="metric">
                <strong>{metric.value}</strong>
                <span>{metric.label}</span>
              </div>
            ))}
          </div>

          <figure class="case-photo case-photo-main">
            <picture>
              <source media="(max-width: 800px)" srcset={`${base}/images/moscow-week-768.jpg`} />
              <img
                src={`${base}/images/moscow-week-1536.jpg`}
                alt="Татьяна на Московской неделе предпринимательства 2026"
                width="1536"
                height="2048"
                loading="lazy"
              />
            </picture>
            <figcaption>Московская неделя предпринимательства · 2026</figcaption>
          </figure>

          <div class="case-side">
            <figure class="case-photo case-photo-secondary">
              <picture>
                <source media="(max-width: 800px)" srcset={`${base}/images/academy-576.jpg`} />
                <img
                  src={`${base}/images/academy-1152.jpg`}
                  alt="Татьяна на площадке Академии инноваторов"
                  width="1152"
                  height="2048"
                  loading="lazy"
                />
              </picture>
              <figcaption>День технологий · Академия инноваторов</figcaption>
            </figure>
            <div class="case-copy">
              <p>
                Вела Telegram-каналы «Кадры для бизнеса», «День без турникетов» и «Студфест»:
                контент-планы, тексты, дизайн публикаций, анимация, партнёрские интеграции и
                освещение мероприятий в реальном времени.
              </p>
              <p>
                Для «Студфеста» участвовала в запуске канала с нуля и сопровождала фестиваль с
                аудиторией более 30 000 зарегистрированных участников и 10 000 гостей.
              </p>
            </div>
          </div>
        </div>

        <div class="case-quote">
          <span aria-hidden="true">“</span>
          <p>Контент здесь — не постфактум. Он становится частью события и помогает аудитории прожить его в моменте.</p>
        </div>
      </section>

      <section class="projects section-shell" id="projects" aria-labelledby="projects-title">
        <div class="projects-heading">
          <h2 id="projects-title">Опыт в разных<br />индустриях</h2>
        </div>

        <div class="project-list">
          {projects.map((project) => (
            <article class="project-item">
              <div class="project-title">
                <p>{project.field}</p>
                <h3>{project.name}</h3>
              </div>
              <p class="project-text">{project.text}</p>
              <p class="project-result">{project.result}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="skills" id="skills" aria-labelledby="skills-title">
        <div class="section-shell skills-shell">
          <div>
            <h2 id="skills-title">Что я умею</h2>
          </div>
          <ul class="skill-cloud">
            {skills.map((skill) => <li>{skill}</li>)}
          </ul>
        </div>
      </section>

      <section class="experience section-shell" id="experience" aria-labelledby="experience-title">
        <div class="experience-heading">
          <h2 id="experience-title">Профессиональная<br />траектория</h2>
        </div>
        <ol class="experience-list">
          {experience.map(([year, company, role]) => (
            <li>
              <time>{year}</time>
              <strong>{company}</strong>
              <span>{role}</span>
            </li>
          ))}
        </ol>
      </section>

      <section class="contact" id="contact" aria-labelledby="contact-title">
        <span class="contact-arc" aria-hidden="true"></span>
        <p>Открыта к предложениям</p>
        <h2 id="contact-title">Обсудим<br />вакансию?</h2>
        <a class="button button-light button-contact" href="https://t.me/tanyakrasavtseva" target="_blank" rel="noreferrer">
          Написать Татьяне
          <span aria-hidden="true">↗</span>
        </a>
        <div class="contact-footer">
          <span>Татьяна Красавцева · Москва</span>
          <span>Content Manager &amp; digital-коммуникации</span>
        </div>
      </section>
    </main>

    <script>
      const header = document.querySelector(".site-header");
      const hero = document.querySelector(".hero");

      if (header && hero) {
        const observer = new IntersectionObserver(
          ([entry]) => header.classList.toggle("is-scrolled", !entry.isIntersecting),
          { threshold: 0.15 },
        );
        observer.observe(hero);
      }
    </script>
  </body>
</html>
